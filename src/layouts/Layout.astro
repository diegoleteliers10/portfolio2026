---
import "../styles/globals.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title,
  description = "Software & Data Engineer | AI - Construcción de soluciones prácticas con tecnología, datos e inteligencia artificial. Desarrollo web, mobile, dashboards y Machine Learning.",
  image = "/og-image.png",
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteURL = "https://dlsdev.vercel.app";
const fullTitle = title.includes("Diego") ? title : `${title} | Diego Letelier`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="author" content="Diego Letelier" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteURL}${image}`} />
    <meta property="og:site_name" content="Diego Letelier - Portfolio" />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteURL}${image}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Preconnect to external domains -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Diego Letelier",
      "alternateName": "Diego José Letelier Salbach",
      "url": siteURL,
      "image": `${siteURL}/favicon.svg`,
      "jobTitle": "Software & Data Engineer",
      "description": description,
      "nationality": {
        "@type": "Country",
        "name": "Chile"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Santiago",
        "addressRegion": "Metropolitana",
        "addressCountry": "CL"
      },
      "email": "dleteliersr@gmail.com",
      "sameAs": [
        "https://www.linkedin.com/in/diegoleteliers10/"
      ],
      "knowsAbout": [
        "Next.js",
        "TypeScript",
        "React",
        "Python",
        "SQL",
        "NestJS",
        "Supabase",
        "Expo",
        "Django",
        "Power BI",
        "Machine Learning"
      ],
      "worksFor": [
        {
          "@type": "Organization",
          "name": "Biovity",
          "url": siteURL
        }
      ],
      "alumniOf": [
        {
          "@type": "CollegeOrUniversity",
          "name": "Universidad del Desarrollo"
        },
        {
          "@type": "EducationalOrganization",
          "name": "Henry"
        }
      ]
    })} />

    <!-- WebSite Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Diego Letelier - Portfolio",
      "url": siteURL,
      "description": description,
      "author": {
        "@type": "Person",
        "name": "Diego Letelier"
      }
    })} />
  </head>
  <body class="bg-[#0a0a0a] text-white font-sans antialiased selection:bg-[#0b3d91]/30 selection:text-white overflow-x-hidden">
    <slot />
  </body>
</html>
