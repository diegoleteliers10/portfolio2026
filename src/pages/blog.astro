---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

// Mock blog posts data - en un proyecto real esto vendría de un CMS o API
const blogPosts = [
  {
    id: 1,
    title: "El Futuro del Desarrollo Web: Astro vs Next.js",
    slug: "futuro-desarrollo-web-astro-vs-nextjs",
    excerpt: "Una comparación profunda entre dos de los frameworks más populares para desarrollo web moderno.",
    content: "Lorem ipsum dolor sit amet, consectetur adipiscing elit...",
    author: "Diego Letelier",
    publishDate: "2024-01-15",
    readTime: "8 min",
    tags: ["JavaScript", "Astro", "Next.js", "Web Development"],
    featured: true,
    color: "primary"
  },
  {
    id: 2,
    title: "Construyendo una Fintech desde Cero",
    slug: "construyendo-fintech-desde-cero",
    excerpt: "Mi experiencia desarrollando una aplicación financiera y las lecciones aprendidas en el camino.",
    content: "Lorem ipsum dolor sit amet, consectetur adipiscing elit...",
    author: "Diego Letelier",
    publishDate: "2024-01-08",
    readTime: "12 min",
    tags: ["Fintech", "Startup", "React", "Node.js"],
    featured: false,
    color: "secondary"
  },
  {
    id: 3,
    title: "Neobrutalism en el Diseño Web: Guía Completa",
    slug: "neobrutalism-diseno-web-guia-completa",
    excerpt: "Todo lo que necesitas saber sobre el neobrutalism y cómo implementarlo en tus proyectos web.",
    content: "Lorem ipsum dolor sit amet, consectetur adipiscing elit...",
    author: "Diego Letelier",
    publishDate: "2024-01-01",
    readTime: "10 min",
    tags: ["Design", "CSS", "UI/UX", "Neobrutalism"],
    featured: false,
    color: "accent"
  },
  {
    id: 4,
    title: "TypeScript para Desarrolladores JavaScript",
    slug: "typescript-para-desarrolladores-javascript",
    excerpt: "Guía práctica para migrar de JavaScript a TypeScript sin dolor de cabeza.",
    content: "Lorem ipsum dolor sit amet, consectetur adipiscing elit...",
    author: "Diego Letelier",
    publishDate: "2023-12-20",
    readTime: "15 min",
    tags: ["TypeScript", "JavaScript", "Programming"],
    featured: false,
    color: "primary"
  },
  {
    id: 5,
    title: "Docker para Desarrolladores Frontend",
    slug: "docker-para-desarrolladores-frontend",
    excerpt: "Aprende a usar Docker para mejorar tu workflow de desarrollo frontend.",
    content: "Lorem ipsum dolor sit amet, consectetur adipiscing elit...",
    author: "Diego Letelier",
    publishDate: "2023-12-10",
    readTime: "6 min",
    tags: ["Docker", "DevOps", "Frontend"],
    featured: false,
    color: "secondary"
  }
];

const featuredPost = blogPosts.find(post => post.featured);
const regularPosts = blogPosts.filter(post => !post.featured);
---

<Layout title="Blog | Diego Letelier - Artículos sobre Desarrollo Web">
  <Navigation />

  <main class="min-h-screen bg-background">
    <!-- Hero Section -->
    <section class="section-brutal">
      <div class="container-brutal">
        <div class="text-center mb-16">
          <div class="accent-block inline-block mb-6">BLOG</div>
          <h1 class="text-brutal mb-6">ARTÍCULOS & TUTORIALES</h1>
          <p class="text-xl font-semibold max-w-3xl mx-auto">
            Comparto mis experiencias, tutoriales y reflexiones sobre
            <span class="neon-green">desarrollo web</span>,
            <span class="neon-blue">fintech</span> y
            <span class="neon-pink">tecnología</span> en general.
          </p>
        </div>
      </div>
    </section>

    <!-- Featured Article -->
    {featuredPost && (
      <section class="section-brutal bg-muted">
        <div class="container-brutal">
          <h2 class="text-2xl font-black uppercase mb-8 text-center">ARTÍCULO DESTACADO</h2>

          <article class="brutal-card p-8 bg-card hover-lift max-w-4xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
              <div class="space-y-6">
                <div class="flex items-center gap-4 mb-4">
                  <span class="accent-block text-sm">FEATURED</span>
                  <span class="skill-tag text-xs bg-primary text-primary-foreground">
                    {featuredPost.readTime} LECTURA
                  </span>
                </div>

                <h3 class="text-3xl font-black uppercase text-primary leading-tight">
                  {featuredPost.title}
                </h3>

                <p class="text-lg font-semibold text-muted-foreground">
                  {featuredPost.excerpt}
                </p>

                <div class="flex flex-wrap gap-2 mb-6">
                  {featuredPost.tags.map((tag, index) => (
                    <span
                      class="skill-tag text-xs"
                      style={index % 3 === 0
                        ? 'background: var(--primary); color: var(--primary-foreground);'
                        : index % 3 === 1
                        ? 'background: var(--secondary); color: var(--secondary-foreground);'
                        : 'background: var(--accent); color: var(--accent-foreground);'
                      }
                    >
                      {tag.toUpperCase()}
                    </span>
                  ))}
                </div>

                <div class="flex items-center gap-4 text-sm">
                  <span class="font-bold">Por {featuredPost.author}</span>
                  <span class="opacity-60">•</span>
                  <time class="opacity-80">
                    {new Date(featuredPost.publishDate).toLocaleDateString('es-ES', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                </div>

                <a
                  href={`/blog/${featuredPost.slug}`}
                  class="brutal-button px-8 py-4 bg-primary text-primary-foreground inline-flex items-center gap-2"
                >
                  LEER ARTÍCULO
                  <span class="text-lg">→</span>
                </a>
              </div>

              <div class="brutal-card p-6 bg-primary text-primary-foreground">
                <div class="aspect-video bg-black bg-opacity-20 border-brutal flex items-center justify-center">
                  <span class="text-4xl">📝</span>
                </div>
                <div class="mt-4 text-center">
                  <p class="font-black text-sm uppercase tracking-wide">ARTÍCULO DESTACADO</p>
                </div>
              </div>
            </div>
          </article>
        </div>
      </section>
    )}

    <!-- Articles Grid -->
    <section class="section-brutal">
      <div class="container-brutal">
        <h2 class="text-2xl font-black uppercase mb-12 text-center">TODOS LOS ARTÍCULOS</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
          {regularPosts.map((post, index) => (
            <article class="brutal-card p-6 bg-card hover-lift h-full flex flex-col">
              <!-- Article Header -->
              <div class="mb-4">
                <div class="flex items-center justify-between mb-3">
                  <span class="skill-tag text-xs bg-muted text-foreground">
                    {post.readTime} LECTURA
                  </span>
                  <time class="text-xs font-bold opacity-60">
                    {new Date(post.publishDate).toLocaleDateString('es-ES', {
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                </div>

                <h3 class="text-xl font-black uppercase leading-tight mb-3 hover:text-primary transition-colors">
                  <a href={`/blog/${post.slug}`} class="hover-lift">
                    {post.title}
                  </a>
                </h3>
              </div>

              <!-- Article Preview -->
              <div class="flex-grow mb-6">
                <p class="text-muted-foreground font-medium leading-relaxed">
                  {post.excerpt}
                </p>
              </div>

              <!-- Tags -->
              <div class="mb-6">
                <div class="flex flex-wrap gap-2">
                  {post.tags.slice(0, 3).map((tag, tagIndex) => (
                    <span
                      class="skill-tag text-xs"
                      style={tagIndex % 3 === 0
                        ? 'background: var(--primary); color: var(--primary-foreground);'
                        : tagIndex % 3 === 1
                        ? 'background: var(--secondary); color: var(--secondary-foreground);'
                        : 'background: var(--accent); color: var(--accent-foreground);'
                      }
                    >
                      {tag.toUpperCase()}
                    </span>
                  ))}
                  {post.tags.length > 3 && (
                    <span class="skill-tag text-xs bg-muted text-foreground">
                      +{post.tags.length - 3}
                    </span>
                  )}
                </div>
              </div>

              <!-- Read More Button -->
              <div class="mt-auto">
                <a
                  href={`/blog/${post.slug}`}
                  class="brutal-button px-6 py-3 text-sm w-full text-center inline-flex items-center justify-center gap-2"
                  style={index % 3 === 0
                    ? 'background: var(--primary); color: var(--primary-foreground);'
                    : index % 3 === 1
                    ? 'background: var(--secondary); color: var(--secondary-foreground);'
                    : 'background: var(--accent); color: var(--accent-foreground);'
                  }
                >
                  LEER MÁS
                  <span class="text-base">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter Subscription -->
    <section class="section-brutal bg-black text-white">
      <div class="container-brutal">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-brutal mb-6 text-white">MANTENTE AL DÍA</h2>
          <p class="text-xl font-semibold mb-8 max-w-2xl mx-auto">
            Suscríbete para recibir los últimos artículos sobre
            <span class="neon-green">desarrollo web</span> y
            <span class="neon-pink">tecnología</span> directamente en tu email.
          </p>

          <div class="brutal-card p-8 bg-white text-black max-w-2xl mx-auto">
            <form class="flex flex-col sm:flex-row gap-4">
              <input
                type="email"
                placeholder="tu@email.com"
                class="flex-grow brutal-input px-6 py-4 font-semibold"
                required
              />
              <button
                type="submit"
                class="brutal-button px-8 py-4 bg-primary text-primary-foreground font-black uppercase tracking-wide"
              >
                SUSCRIBIRME
              </button>
            </form>
            <p class="text-sm font-medium mt-4 opacity-70">
              Sin spam. Solo contenido de calidad. Puedes cancelar cuando quieras.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Tags Cloud -->
    <section class="section-brutal">
      <div class="container-brutal">
        <h2 class="text-2xl font-black uppercase mb-8 text-center">TOPICS</h2>

        <div class="flex flex-wrap justify-center gap-3">
          {['JavaScript', 'TypeScript', 'React', 'Node.js', 'Astro', 'Next.js', 'Fintech', 'Startup', 'CSS', 'HTML', 'Docker', 'AWS', 'UI/UX', 'Design', 'DevOps', 'Programming', 'Web Development', 'Neobrutalism'].map((tag, index) => (
            <a
              href={`/blog/tag/${tag.toLowerCase().replace(/[^a-z0-9]/g, '-')}`}
              class="skill-tag hover:scale-105 transition-transform"
              style={index % 4 === 0
                ? 'background: var(--primary); color: var(--primary-foreground);'
                : index % 4 === 1
                ? 'background: var(--secondary); color: var(--secondary-foreground);'
                : index % 4 === 2
                ? 'background: var(--accent); color: var(--accent-foreground);'
                : 'background: var(--muted); color: var(--foreground);'
              }
            >
              {tag.toUpperCase()}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Blog specific styles */
  .section-brutal {
    scroll-margin-top: 2rem;
  }

  /* Article card animations */
  article {
    transition: all 0.3s ease;
  }

  article:hover {
    transform: translate(-4px, -4px);
  }

  /* Featured article special styling */
  .featured-article {
    position: relative;
    overflow: hidden;
  }

  .featured-article::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    animation: shimmer 3s infinite;
  }

  @keyframes shimmer {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  /* Newsletter form styling */
  .newsletter-form {
    animation: glow-pulse 4s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%, 100% { box-shadow: var(--shadow-brutal); }
    50% { box-shadow: var(--shadow-brutal-lg), 0 0 20px rgba(0, 255, 148, 0.3); }
  }

  /* Tag cloud hover effects */
  .tag-cloud a {
    position: relative;
    overflow: hidden;
  }

  .tag-cloud a::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s ease;
  }

  .tag-cloud a:hover::before {
    left: 100%;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .featured-article .grid {
      grid-template-columns: 1fr;
    }

    .newsletter-form {
      flex-direction: column;
    }
  }

  /* Print styles */
  @media print {
    .newsletter-form,
    .tag-cloud {
      display: none;
    }

    article {
      box-shadow: none;
      border: 2px solid #000;
      break-inside: avoid;
      margin-bottom: 1rem;
    }
  }
</style>

<script>
  // Blog page interactivity
  document.addEventListener('DOMContentLoaded', function() {
    // Newsletter form handling
    const newsletterForm = document.querySelector('form');
    if (newsletterForm) {
      newsletterForm.addEventListener('submit', function(e) {
        e.preventDefault();

        const email = this.querySelector('input[type="email"]').value;

        // Simulate subscription (replace with real API call)
        setTimeout(() => {
          alert(`¡Gracias por suscribirte con ${email}! Te enviaremos contenido increíble.`);
          this.reset();
        }, 500);
      });
    }

    // Add reading time calculation for articles
    const articles = document.querySelectorAll('article');
    articles.forEach(article => {
      const text = article.textContent;
      const wordsPerMinute = 200;
      const wordCount = text.split(/\s+/).length;
      const readingTime = Math.ceil(wordCount / wordsPerMinute);

      // You can use this data for dynamic reading time updates
    });

    // Smooth scroll for tag links
    const tagLinks = document.querySelectorAll('a[href^="/blog/tag/"]');
    tagLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        // Add visual feedback
        this.style.transform = 'scale(0.95)';
        setTimeout(() => {
          this.style.transform = 'scale(1)';
        }, 150);
      });
    });

    // Add view tracking (replace with real analytics)
    console.log('Blog page viewed:', new Date().toISOString());
  });
</script>
