---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Diego Martínez - Full Stack Developer">
  <Header />

  <main
    class="flex-grow flex items-center justify-center px-6 lg:px-16 pt-32 pb-16 w-full max-w-[1920px] mx-auto"
  >
    <div class="text-center space-y-8 max-w-4xl mx-auto">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="flex gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#0b3d91]"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-[#0b3d91]/30"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-[#0b3d91]/10"></span>
        </div>
        <span
          class="text-[11px] font-bold uppercase tracking-[0.25em] text-[#52525b]"
          >Full Stack Developer</span
        >
      </div>

      <h1
        class="font-serif text-6xl md:text-7xl lg:text-[7rem] xl:text-[8rem] leading-[0.9] text-[#18181b] tracking-tighter mb-8"
      >
        Diego<br />
        <span class="italic font-light text-zinc-300">Martínez</span><span
          class="text-[#0b3d91]">.</span
        >
      </h1>

      <div class="max-w-2xl mx-auto space-y-6">
        <p class="text-lg md:text-xl text-[#52525b] font-light leading-relaxed">
          Creando soluciones digitales donde la <span
            class="font-medium text-[#18181b] border-b border-[#0b3d91]/40"
            >funcionalidad</span
          > se encuentra con la <span
            class="font-medium text-[#18181b] border-b border-[#0b3d91]/40"
            >elegancia</span
          >. Un enfoque clásico para el desarrollo moderno.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-8 pt-4">
          <a
            class="group flex items-center gap-3 text-[#18181b] font-semibold border-b-2 border-[#18181b] pb-1 hover:border-[#0b3d91] hover:text-[#0b3d91] transition-all duration-300"
            href="#proyectos"
          >
            Ver Portfolio
            <span
              class="material-symbols-outlined text-xl transition-transform group-hover:translate-x-1"
              >arrow_forward</span
            >
          </a>

          <div class="flex gap-4 items-center pl-4 border-l border-zinc-200">
            <span class="text-xs font-mono text-[#a1a1aa]">React</span>
            <span class="text-xs font-mono text-[#a1a1aa]">Node.js</span>
            <span class="text-xs font-mono text-[#a1a1aa]">TS</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Sección Sobre Mí -->
  <section id="about" class="py-16">
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 py-16">
      <div class="flex flex-col lg:flex-row gap-16">
        <aside class="w-full lg:w-1/3 xl:w-1/4 flex-shrink-0">
          <div class="sticky top-28 flex flex-col gap-8">
            <div
              class="relative w-full aspect-[4/5] rounded-none overflow-hidden bg-zinc-50"
            >
              <img
                alt="Portrait of software developer Alejandro smiling in a modern office setting"
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
                data-alt="Portrait of software developer Alejandro smiling"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBTvZVDG3FZV7OLXCes1rT-Thkp0AUG_xT5uWepgpMWJ3WsDit21tTnvtnfzH9i9F3BDGlNjEN8A5-RcZjlz3KQoYnaP1tRcUSlmi9G2ik3ha59D1YMZ41qs-cGQiNcj3xJuOPEV_4OTtZzSGm4qfXO26EOP6Sa0_1YmmBVBUvy8DMgJXR_3X5YEZpcmRfLeKlIHyyxjYT_rTBZnNtM45I9vDhbUBtM1iQbpiwunuwsBpxVnDLxL_LJXVWHBqDgVhk_VM9MC7_Seqo"
              />
              <div
                class="absolute bottom-0 left-0 w-full h-1/3 bg-gradient-to-t from-white to-transparent"
              >
              </div>
            </div>
            <div
              class="flex flex-col gap-2 border-l-2 border-zinc-900 pl-5 py-1"
            >
              <h1
                class="text-4xl font-bold tracking-tighter text-zinc-900 leading-none"
              >
                Alejandro<br />Ruiz
              </h1>
              <p class="text-primary font-mono text-sm tracking-wide mt-2">
                JUNIOR SOFTWARE DEV
              </p>
            </div>
            <div class="space-y-4 text-sm text-zinc-600">
              <div class="flex items-start gap-4 group">
                <span
                  class="material-symbols-outlined text-zinc-400 group-hover:text-primary transition-colors text-[20px] mt-0.5"
                  >location_on</span
                >
                <div>
                  <span class="block text-zinc-900 font-medium">Ubicación</span>
                  <span class="font-light">Madrid, España</span>
                </div>
              </div>
              <div class="flex items-start gap-4 group">
                <span
                  class="material-symbols-outlined text-zinc-400 group-hover:text-primary transition-colors text-[20px] mt-0.5"
                  >translate</span
                >
                <div>
                  <span class="block text-zinc-900 font-medium">Idiomas</span>
                  <span class="font-light">Español (Nativo), Inglés (C1)</span>
                </div>
              </div>
            </div>
            <div class="flex gap-4 pt-4 border-t border-zinc-100">
              <a
                class="w-10 h-10 flex items-center justify-center border border-zinc-200 text-zinc-500 hover:text-white hover:bg-zinc-900 hover:border-zinc-900 transition-all duration-300 rounded-full"
                href="#"
              >
                <span class="material-symbols-outlined text-[18px]">code</span>
              </a>
              <a
                class="w-10 h-10 flex items-center justify-center border border-zinc-200 text-zinc-500 hover:text-white hover:bg-zinc-900 hover:border-zinc-900 transition-all duration-300 rounded-full"
                href="#"
              >
                <span class="material-symbols-outlined text-[18px]">work</span>
              </a>
              <a
                class="w-10 h-10 flex items-center justify-center border border-zinc-200 text-zinc-500 hover:text-white hover:bg-zinc-900 hover:border-zinc-900 transition-all duration-300 rounded-full"
                href="#"
              >
                <span class="material-symbols-outlined text-[18px]">mail</span>
              </a>
            </div>
          </div>
        </aside>
        <div class="flex-1 space-y-20">
          <section class="max-w-3xl">
            <div
              class="inline-flex items-center gap-2 px-3 py-1 bg-zinc-50 border border-zinc-100 rounded-full text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-6"
            >
              <span class="w-2 h-2 rounded-full bg-primary animate-pulse"
              ></span>
              Disponible para trabajar
            </div>
            <h2
              class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 mb-8 leading-tight"
            >
              Desarrollando soluciones digitales con <span
                class="relative inline-block text-zinc-900"
                >precisión<span
                  class="absolute -bottom-1 left-0 w-full h-2 bg-primary/20 -z-10"
                ></span></span
              > y propósito.
            </h2>
            <div
              class="text-lg md:text-xl text-zinc-500 font-light leading-relaxed space-y-6"
            >
              <p>
                Soy un desarrollador apasionado por la arquitectura de software
                y el diseño de interfaces limpias. Mi objetivo es crear
                experiencias web que no solo funcionen perfectamente, sino que
                también sean intuitivas y agradables para el usuario final.
              </p>
              <p>
                Con un enfoque disciplinado y minimalista, transformo
                requerimientos complejos en código eficiente y mantenible.
              </p>
            </div>
            <div
              class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-12 pt-10 border-t border-zinc-100"
            >
              <div>
                <span class="block text-4xl font-bold text-zinc-900 mb-1"
                  >03</span
                >
                <span
                  class="text-xs font-medium uppercase tracking-widest text-zinc-400"
                  >Años Exp.</span
                >
              </div>
              <div>
                <span class="block text-4xl font-bold text-zinc-900 mb-1"
                  >15+</span
                >
                <span
                  class="text-xs font-medium uppercase tracking-widest text-zinc-400"
                  >Proyectos</span
                >
              </div>
              <div>
                <span class="block text-4xl font-bold text-zinc-900 mb-1"
                  >100%</span
                >
                <span
                  class="text-xs font-medium uppercase tracking-widest text-zinc-400"
                  >Remoto</span
                >
              </div>
            </div>
          </section>
          <section>
            <h3
              class="flex items-center gap-3 text-2xl font-bold text-zinc-900 mb-10"
            >
              <span class="w-8 h-[2px] bg-primary"></span>
              Trayectoria
            </h3>
            <div
              class="relative border-l border-zinc-200 ml-3 md:ml-4 space-y-12 pb-4"
            >
              <div class="relative pl-8 md:pl-12 group">
                <div
                  class="absolute -left-[5px] top-2 w-[11px] h-[11px] rounded-full bg-white border-2 border-zinc-300 group-hover:border-primary group-hover:scale-125 transition-all duration-300"
                >
                </div>
                <div
                  class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2"
                >
                  <h4
                    class="text-lg font-bold text-zinc-900 group-hover:text-primary transition-colors"
                  >
                    Frontend Developer
                  </h4>
                  <span
                    class="text-xs font-mono text-zinc-400 bg-zinc-50 px-2 py-1 rounded"
                    >2023 — Presente</span
                  >
                </div>
                <p class="text-sm font-medium text-zinc-700 mb-2">Freelance</p>
                <p class="text-zinc-500 font-light leading-relaxed max-w-2xl">
                  Especialización en desarrollo de interfaces modernas
                  utilizando React y Next.js. Colaboración directa con clientes
                  internacionales para optimizar el rendimiento web y la
                  experiencia de usuario (UX). Implementación de sistemas de
                  diseño escalables.
                </p>
              </div>
              <div class="relative pl-8 md:pl-12 group">
                <div
                  class="absolute -left-[5px] top-2 w-[11px] h-[11px] rounded-full bg-white border-2 border-zinc-300 group-hover:border-primary group-hover:scale-125 transition-all duration-300"
                >
                </div>
                <div
                  class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2"
                >
                  <h4
                    class="text-lg font-bold text-zinc-900 group-hover:text-primary transition-colors"
                  >
                    Bootcamp Full Stack Web Dev
                  </h4>
                  <span
                    class="text-xs font-mono text-zinc-400 bg-zinc-50 px-2 py-1 rounded"
                    >2022 — 2023</span
                  >
                </div>
                <p class="text-sm font-medium text-zinc-700 mb-2">Ironhack</p>
                <p class="text-zinc-500 font-light leading-relaxed max-w-2xl">
                  Formación intensiva de +400 horas centrada en el stack MERN
                  (MongoDB, Express, React, Node.js). Desarrollo de 3 proyectos
                  completos aplicando metodologías ágiles y control de versiones
                  con Git.
                </p>
              </div>
              <div class="relative pl-8 md:pl-12 group">
                <div
                  class="absolute -left-[5px] top-2 w-[11px] h-[11px] rounded-full bg-white border-2 border-zinc-300 group-hover:border-primary group-hover:scale-125 transition-all duration-300"
                >
                </div>
                <div
                  class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2"
                >
                  <h4
                    class="text-lg font-bold text-zinc-900 group-hover:text-primary transition-colors"
                  >
                    Grado en Ingeniería Informática
                  </h4>
                  <span
                    class="text-xs font-mono text-zinc-400 bg-zinc-50 px-2 py-1 rounded"
                    >2018 — 2022</span
                  >
                </div>
                <p class="text-sm font-medium text-zinc-700 mb-2">
                  Universidad Politécnica de Madrid
                </p>
                <p class="text-zinc-500 font-light leading-relaxed max-w-2xl">
                  Adquisición de una base sólida en algoritmos, estructuras de
                  datos y paradigmas de programación. Participación activa en el
                  club de programación de la universidad.
                </p>
              </div>
            </div>
          </section>
          <section>
            <h3
              class="flex items-center gap-3 text-2xl font-bold text-zinc-900 mb-10"
            >
              <span class="w-8 h-[2px] bg-primary"></span>
              Habilidades Técnicas
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              <div
                class="p-6 bg-zinc-50 rounded-sm border border-zinc-100 hover:border-zinc-300 hover:shadow-sm transition-all duration-300 group"
              >
                <div class="flex items-center justify-between mb-4">
                  <h4
                    class="font-bold text-zinc-900 text-sm uppercase tracking-wider"
                  >
                    Frontend
                  </h4>
                  <span
                    class="material-symbols-outlined text-zinc-300 group-hover:text-primary transition-colors"
                    >html</span
                  >
                </div>
                <div class="flex flex-wrap gap-2">
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >React</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Next.js</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >TypeScript</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Tailwind</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Redux</span
                  >
                </div>
              </div>
              <div
                class="p-6 bg-zinc-50 rounded-sm border border-zinc-100 hover:border-zinc-300 hover:shadow-sm transition-all duration-300 group"
              >
                <div class="flex items-center justify-between mb-4">
                  <h4
                    class="font-bold text-zinc-900 text-sm uppercase tracking-wider"
                  >
                    Backend
                  </h4>
                  <span
                    class="material-symbols-outlined text-zinc-300 group-hover:text-primary transition-colors"
                    >dns</span
                  >
                </div>
                <div class="flex flex-wrap gap-2">
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Node.js</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Express</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >PostgreSQL</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >MongoDB</span
                  >
                </div>
              </div>
              <div
                class="p-6 bg-zinc-50 rounded-sm border border-zinc-100 hover:border-zinc-300 hover:shadow-sm transition-all duration-300 group"
              >
                <div class="flex items-center justify-between mb-4">
                  <h4
                    class="font-bold text-zinc-900 text-sm uppercase tracking-wider"
                  >
                    Tools &amp; Others
                  </h4>
                  <span
                    class="material-symbols-outlined text-zinc-300 group-hover:text-primary transition-colors"
                    >build</span
                  >
                </div>
                <div class="flex flex-wrap gap-2">
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Git / GitHub</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Docker</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Figma</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Jest</span
                  >
                  <span
                    class="px-3 py-1 bg-white border border-zinc-200 text-zinc-600 text-xs font-medium rounded-sm"
                    >Vercel</span
                  >
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>
  </section>

  <!-- Sección Proyectos -->
  <section id="proyectos" class="px-6 lg:px-16 py-20">
    <div class="max-w-[1920px] mx-auto">
      <div class="text-center space-y-4 mb-16">
        <h2 class="font-serif text-5xl text-[#18181b]">Proyectos Destacados</h2>
        <div class="w-12 h-[2px] bg-[#0b3d91] mx-auto"></div>
        <p class="text-lg text-[#52525b] max-w-2xl mx-auto">
          Una selección de proyectos que demuestran mi experiencia técnica y
          enfoque en soluciones innovadoras.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Proyecto 1 -->
        <div class="group relative">
          <div
            class="absolute top-4 left-4 w-full h-full border border-[#18181b]/10 group-hover:top-2 group-hover:left-2 transition-all duration-300"
          >
          </div>
          <div
            class="relative bg-white p-8 shadow-lg border border-zinc-50 space-y-6"
          >
            <div class="flex items-center gap-3">
              <div class="w-3 h-3 rounded-full bg-[#0b3d91]"></div>
              <span
                class="text-xs font-bold uppercase tracking-widest text-[#a1a1aa]"
                >FinTech</span
              >
            </div>

            <h3 class="font-serif text-2xl text-[#18181b]">
              Plataforma de Inversión
            </h3>

            <p class="text-[#52525b] leading-relaxed">
              Aplicación web completa que conecta inversores con oportunidades
              de startups. Incluye dashboard en tiempo real, sistema de pagos
              seguro y análisis de datos avanzado.
            </p>

            <div class="flex flex-wrap gap-2">
              <span
                class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                >React</span
              >
              <span
                class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                >Node.js</span
              >
              <span
                class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                >PostgreSQL</span
              >
              <span
                class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                >Stripe</span
              >
            </div>

            <div class="flex gap-4 pt-4">
              <a
                href="#"
                class="text-sm font-medium text-[#0b3d91] border-b border-[#0b3d91] hover:border-[#083066] transition-colors"
              >
                Ver Demo
              </a>
              <a
                href="https://github.com/diegoletelier"
                target="_blank"
                class="text-sm font-medium text-[#52525b] hover:text-[#18181b] transition-colors"
              >
                Código
              </a>
            </div>
          </div>
        </div>

        <!-- Proyecto 2 -->
        <div class="group relative">
          <div
            class="absolute top-4 left-4 w-full h-full border border-[#18181b]/10 group-hover:top-2 group-hover:left-2 transition-all duration-300"
          >
          </div>
          <div
            class="relative bg-white p-8 shadow-lg border border-zinc-50 space-y-6"
          >
            <div class="flex items-center gap-3">
              <div class="w-3 h-3 rounded-full bg-[#0b3d91]"></div>
              <span
                class="text-xs font-bold uppercase tracking-widest text-[#a1a1aa]"
                >E-commerce</span
              >
            </div>

            <h3 class="font-serif text-2xl text-[#18181b]">Tienda Online</h3>

            <p class="text-[#52525b] leading-relaxed">
              Sistema completo de comercio electrónico con gestión de
              inventario, carrito de compras, procesamiento de pagos y panel de
              administración.
            </p>

            <div class="flex flex-wrap gap-2">
              <span
                class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                >Next.js</span
              >
              <span
                class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                >MongoDB</span
              >
              <span
                class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                >Tailwind</span
              >
              <span
                class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                >PayPal</span
              >
            </div>

            <div class="flex gap-4 pt-4">
              <a
                href="#"
                class="text-sm font-medium text-[#0b3d91] border-b border-[#0b3d91] hover:border-[#083066] transition-colors"
              >
                Ver Demo
              </a>
              <a
                href="https://github.com/diegoletelier"
                target="_blank"
                class="text-sm font-medium text-[#52525b] hover:text-[#18181b] transition-colors"
              >
                Código
              </a>
            </div>
          </div>
        </div>

        <!-- Proyecto 3 -->
        <div class="group relative lg:col-span-2">
          <div
            class="absolute top-4 left-4 w-full h-full border border-[#18181b]/10 group-hover:top-2 group-hover:left-2 transition-all duration-300"
          >
          </div>
          <div class="relative bg-white p-8 shadow-lg border border-zinc-50">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
              <div class="space-y-6">
                <div class="flex items-center gap-3">
                  <div class="w-3 h-3 rounded-full bg-[#0b3d91]"></div>
                  <span
                    class="text-xs font-bold uppercase tracking-widest text-[#a1a1aa]"
                    >Productividad</span
                  >
                </div>

                <h3 class="font-serif text-3xl text-[#18181b]">
                  Gestor de Tareas
                </h3>

                <p class="text-[#52525b] leading-relaxed">
                  Aplicación de gestión de proyectos con colaboración en tiempo
                  real, notificaciones push, métricas de productividad y
                  integración con herramientas populares.
                </p>

                <div class="flex flex-wrap gap-2">
                  <span
                    class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                    >Vue.js</span
                  >
                  <span
                    class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                    >Express</span
                  >
                  <span
                    class="text-xs px-3 py-1 bg-zinc-100 text-[#a1a1aa] font-mono"
                    >Socket.io</span
                  >
                  <span
