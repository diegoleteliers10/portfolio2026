---

---

<header
  class="fixed top-0 z-50 w-full bg-white/90 backdrop-blur-md border-b border-zinc-100"
>
  <div
    class="flex items-center justify-between px-6 py-5 lg:px-16 max-w-[1920px] mx-auto w-full"
  >
    <a
      class="text-xl font-bold tracking-tight font-serif text-[#18181b] group"
      href="/"
    >
      D<span class="text-[#0b3d91] group-hover:opacity-60 transition-opacity"
        >.</span
      >
    </a>
    <nav class="hidden md:flex items-center gap-10">
      <a
        class="text-sm font-medium text-[#52525b] hover:text-[#18181b] transition-colors"
        href="#about">Sobre Mí</a
      >
      <a
        class="text-sm font-medium text-[#52525b] hover:text-[#18181b] transition-colors"
        href="#proyectos">Proyectos</a
      >
      <a
        class="text-sm font-medium text-[#52525b] hover:text-[#18181b] transition-colors"
        href="#experiencia">Experiencia</a
      >
    </nav>
    <div class="flex items-center gap-4">
      <a
        class="hidden md:inline-flex items-center justify-center px-6 py-2 text-sm font-medium text-white bg-[#18181b] hover:bg-[#0b3d91] transition-colors duration-300 shadow-sm"
        href="#contacto"
      >
        Contacto
      </a>
      <button id="mobile-menu-button" class="md:hidden text-[#18181b] p-2">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-white border-t border-zinc-100"
  >
    <nav class="px-6 py-4 space-y-4">
      <a
        class="block text-sm font-medium text-[#52525b] hover:text-[#18181b] transition-colors"
        href="#about">Sobre Mí</a
      >
      <a
        class="block text-sm font-medium text-[#52525b] hover:text-[#18181b] transition-colors"
        href="#proyectos">Proyectos</a
      >
      <a
        class="block text-sm font-medium text-[#52525b] hover:text-[#18181b] transition-colors"
        href="#experiencia">Experiencia</a
      >
      <a
        class="block text-sm font-medium text-white bg-[#18181b] hover:bg-[#0b3d91] transition-colors duration-300 shadow-sm px-4 py-2 text-center"
        href="#contacto"
      >
        Contacto
      </a>
    </nav>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener("click", function () {
        mobileMenu.classList.toggle("hidden");
      });

      // Close mobile menu when clicking on a link
      const mobileLinks = mobileMenu.querySelectorAll("a");
      mobileLinks.forEach((link) => {
        link.addEventListener("click", function () {
          mobileMenu.classList.add("hidden");
        });
      });
    }

    // Smooth scrolling for navigation links
    const navLinks = document.querySelectorAll('a[href^="#"]');
    navLinks.forEach((link) => {
      link.addEventListener("click", function (e) {
        e.preventDefault();
        const targetId = this.getAttribute("href").substring(1);
        const targetElement = document.getElementById(targetId);

        if (targetElement) {
          const offsetTop = targetElement.offsetTop - 120;
          window.scrollTo({
            top: Math.max(0, offsetTop),
            behavior: "smooth",
          });
        }
      });
    });
  });
</script>
